---
import { getCollection, render } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import { projectSchema } from '../../data/jsonld';

// Required for output: 'static'
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const sorted = projects.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((project, idx) => ({
    params: { slug: project.id },
    props: {
      project,
      prev: sorted[idx - 1] ?? null,
      next: sorted[idx + 1] ?? null
    },
  }));
}

const { project, prev, next } = Astro.props;
const { Content } = await render(project);
const { title, tagline, impact, tech, repo, demo, timeline, architecture } = project.data;

const schema = projectSchema({
  title,
  tagline,
  url: `https://portfolio.jnkfacey.com/projects/${project.id}`
});
---

<ProjectLayout
  title={`${title} — James Facey`}
  description={tagline}
  ogImage={`/og/${project.id}.png`}
  jsonLd={schema}
>
  <nav class="mb-8">
    <a
      href="/#projects"
      class="text-sm transition-colors"
      style="color: var(--color-muted);"
    >
      ← Back to portfolio
    </a>
  </nav>

  <h1 class="text-4xl font-bold" style="color: var(--color-text);">{title}</h1>
  <p class="text-lg mt-2 mb-8" style="color: var(--color-muted);">{tagline}</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
    {impact.map(item => (
      <div
        class="rounded-lg p-4"
        style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
      >
        <p class="text-sm" style="color: color-mix(in srgb, var(--color-text) 80%, transparent);">
          {item}
        </p>
      </div>
    ))}
  </div>

  <div class="prose prose-invert prose-sm max-w-none mb-8">
    <Content />
  </div>

  {architecture && (
    <div
      class="rounded-lg p-6 my-8"
      style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
    >
      <h3 class="font-mono text-sm mb-3" style="color: var(--color-accent);">Architecture</h3>
      <p class="text-sm font-mono" style="color: var(--color-muted);">{architecture}</p>
    </div>
  )}

  <div class="flex flex-wrap gap-2 mt-8">
    {tech.map(t => (
      <span
        class="text-xs px-2 py-1 rounded"
        style="background-color: var(--color-bg); color: var(--color-muted); border: 1px solid var(--color-border);"
      >
        {t}
      </span>
    ))}
  </div>

  {timeline && (
    <p class="text-xs mt-4" style="color: var(--color-muted);">Timeline: {timeline}</p>
  )}

  <div class="flex gap-4 mt-6">
    {repo && (
      <a
        href={repo}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm transition-colors"
        style="color: var(--color-accent);"
      >
        View Repo ↗
      </a>
    )}
    {demo && (
      <a
        href={demo}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm transition-colors"
        style="color: var(--color-accent);"
      >
        Live Demo ↗
      </a>
    )}
  </div>

  <!-- Prev/next navigation — no wrapping (terminates at ends for 3 projects) -->
  <div
    class="flex justify-between mt-16 pt-8"
    style="border-top: 1px solid var(--color-border);"
  >
    <div>
      {prev && (
        <a
          href={`/projects/${prev.id}`}
          class="text-sm transition-colors"
          style="color: var(--color-muted);"
        >
          ← {prev.data.title}
        </a>
      )}
    </div>
    <div>
      {next && (
        <a
          href={`/projects/${next.id}`}
          class="text-sm transition-colors"
          style="color: var(--color-muted);"
        >
          {next.data.title} →
        </a>
      )}
    </div>
  </div>
</ProjectLayout>

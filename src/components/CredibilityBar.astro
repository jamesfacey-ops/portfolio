---
const stats = [
  {
    number: "28",
    label: "production Docker services",
    translation: "I run production infra daily, not sandboxes"
  },
  {
    number: "3-node",
    label: "Proxmox cluster",
    translation: "Bare-metal HA, not just cloud configs"
  },
  {
    number: "27k+",
    label: "vector embeddings in production",
    translation: "Real AI systems, not demos"
  },
  {
    number: "50+",
    label: "n8n automations",
    translation: "I automate my own work the same way I'd do yours"
  },
];
---
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 py-12">
  {stats.map(stat => (
    <div
      class="rounded-lg p-4"
      style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
    >
      <div class="text-2xl font-bold" style="color: var(--color-accent);">{stat.number}</div>
      <div class="text-sm mt-0.5" style="color: var(--color-text);">{stat.label}</div>
      <div class="text-xs mt-2" style="color: var(--color-muted);">{stat.translation}</div>
    </div>
  ))}
</div>

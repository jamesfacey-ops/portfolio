---
const items = [
  {
    icon: "⚡",
    heading: "Async-first",
    detail: "Loom for status updates, written specs before coding starts — no recurring standups unless you want them"
  },
  {
    icon: "✓",
    heading: "Milestone-based delivery",
    detail: "Each milestone has clear acceptance criteria. You approve before I move on."
  },
  {
    icon: "🚀",
    heading: "Ships in weeks, not months",
    detail: "Shamus MVP: 22 microservices in production in 6 weeks."
  },
  {
    icon: "🔍",
    heading: "Honest about tradeoffs",
    detail: "I'll scope-creep-check your requests before building — saves you money and time."
  },
];
---
<section class="py-12 max-w-2xl mx-auto px-4">
  <h2 class="text-2xl font-bold mb-8" style="color: var(--color-text);">How I Work</h2>
  <ul class="space-y-6">
    {items.map(item => (
      <li class="flex gap-4">
        <span class="text-xl w-6 flex-shrink-0">{item.icon}</span>
        <div>
          <h3 class="font-semibold" style="color: var(--color-text);">{item.heading}</h3>
          <p class="text-sm mt-1" style="color: var(--color-muted);">{item.detail}</p>
        </div>
      </li>
    ))}
  </ul>
</section>

---
// TURNSTILE_SITE_KEY is public by Cloudflare design — safe to inline in HTML
const siteKey = import.meta.env.TURNSTILE_SITE_KEY ?? '';
---
<section id="contact" class="py-16 max-w-xl mx-auto px-4">
  <h2 class="text-2xl font-bold mb-2" style="color: var(--color-text);">Let's build something</h2>
  <p class="text-sm mb-8" style="color: var(--color-muted);">I respond within 24–48 hours.</p>

  <form id="contact-form" class="space-y-4">
    <!-- Honeypot: position:absolute hides from real users; display:none is detectable by bots -->
    <input
      type="text"
      name="website"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      style="position:absolute;left:-9999px;opacity:0;height:0;width:0;"
    />

    <div>
      <label for="name" class="block text-sm mb-1" style="color: var(--color-muted);">Name</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="w-full rounded-lg px-3 py-2 focus:outline-none"
        style="background-color: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text);"
      />
    </div>

    <div>
      <label for="email" class="block text-sm mb-1" style="color: var(--color-muted);">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full rounded-lg px-3 py-2 focus:outline-none"
        style="background-color: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text);"
      />
    </div>

    <div>
      <label for="message" class="block text-sm mb-1" style="color: var(--color-muted);">
        What are you trying to build?
      </label>
      <textarea
        id="message"
        name="message"
        rows="4"
        required
        class="w-full rounded-lg px-3 py-2 focus:outline-none resize-none"
        style="background-color: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text);"
      ></textarea>
    </div>

    {siteKey && (
      <div class="cf-turnstile" data-sitekey={siteKey} data-theme="dark"></div>
    )}

    <button
      type="submit"
      id="submit-btn"
      class="w-full text-white font-medium py-3 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      style="background-color: var(--color-accent);"
    >
      Send →
    </button>

    <p id="form-status" class="text-sm" style="display:none;"></p>
  </form>
</section>

<script lang="ts">
// POSTs to /api/contact — nginx proxy_pass to n8n
// The actual n8n webhook URL is NEVER in this bundle (nginx runtime env var)
const form = document.getElementById('contact-form') as HTMLFormElement;
const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
const statusEl = document.getElementById('form-status') as HTMLParagraphElement;

form?.addEventListener('submit', async (e) => {
  e.preventDefault();

  const honeypot = (form.elements.namedItem('website') as HTMLInputElement)?.value;
  if (honeypot) return; // silently block bots

  submitBtn.disabled = true;
  submitBtn.textContent = 'Sending...';

  const turnstileInput = form.elements.namedItem('cf-turnstile-response') as HTMLInputElement | null;

  const data = {
    name: (form.elements.namedItem('name') as HTMLInputElement).value,
    email: (form.elements.namedItem('email') as HTMLInputElement).value,
    message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
    'cf-turnstile-response': turnstileInput?.value ?? '',
  };

  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });

    if (res.ok) {
      statusEl.textContent = "Got it — I'll respond within 24–48 hours.";
      statusEl.style.color = '#34d399'; // emerald-400
      statusEl.style.display = 'block';
      form.reset();
    } else {
      throw new Error('Server error');
    }
  } catch {
    statusEl.textContent = 'Something went wrong. Try emailing directly.';
    statusEl.style.color = '#f87171'; // red-400
    statusEl.style.display = 'block';
    submitBtn.disabled = false;
    submitBtn.textContent = 'Send →';
  }
});
</script>

{siteKey && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

---
interface Props {
  text: string;
  href: string;
}

const { text, href } = Astro.props;
---
<div class="flex justify-center my-12">
  <a
    href={href}
    class="font-medium text-lg transition-colors"
    style="color: var(--color-accent);"
    onmouseover="this.style.color='var(--color-accent-dim)'"
    onmouseout="this.style.color='var(--color-accent)'"
  >
    {text} →
  </a>
</div>

---
import { techAnnotated, techLogosOnly } from '../data/tech';
---
<section class="py-12 max-w-4xl mx-auto px-4">
  <h2 class="text-2xl font-bold mb-8" style="color: var(--color-text);">Tech Stack</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    {techAnnotated.map(t => (
      <div
        class="rounded-lg p-4"
        style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
      >
        <div class="font-mono text-sm font-semibold" style="color: var(--color-accent);">{t.name}</div>
        <div class="text-xs mt-1" style="color: var(--color-muted);">{t.annotation}</div>
      </div>
    ))}
  </div>

  <div class="flex flex-wrap gap-3">
    {techLogosOnly.map(t => (
      <span
        class="text-xs px-3 py-1.5 rounded-md"
        style="background-color: var(--color-bg); border: 1px solid var(--color-border); color: var(--color-muted);"
      >
        {t}
      </span>
    ))}
  </div>

  <div class="mt-6">
    <a
      href="https://github.com/jfacey"
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm transition-colors"
      style="color: var(--color-accent);"
    >
      See production code on GitHub →
    </a>
  </div>
</section>

---
import AvailabilityBadge from './AvailabilityBadge.astro';
---
<section class="min-h-[80vh] flex flex-col justify-center px-4 md:px-8 lg:px-16 max-w-4xl mx-auto">
  <AvailabilityBadge />
  <h1 class="font-mono text-[var(--color-muted)] text-sm mt-6 mb-2">James Facey</h1>
  <h2
    class="font-bold leading-tight text-[var(--color-text)] mb-4"
    style="font-size: clamp(1.75rem, 5vw, 3rem);"
  >
    I build AI integrations and backend<br class="hidden md:block" />
    systems for teams that need to<br class="hidden md:block" />
    ship, not prototype.
  </h2>
  <p class="text-[var(--color-muted)] text-sm md:text-base mb-8">
    Open to contract work · AI integrations · Automation · Backend systems
  </p>
  <a
    href="#projects"
    class="inline-flex items-center gap-2 text-white font-medium px-6 py-3 rounded-lg w-fit transition-colors"
    style="background-color: var(--color-accent);"
    onmouseover="this.style.backgroundColor='var(--color-accent-dim)'"
    onmouseout="this.style.backgroundColor='var(--color-accent)'"
  >
    See My Work ↓
  </a>
</section>

---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, tagline, impact, tech, repo } = project.data;
const displayTech = tech.slice(0, 5);
const extraCount = tech.length > 5 ? tech.length - 5 : 0;
// heroImage not shown on card — used for og:image only on project pages
---
<article
  class="rounded-xl p-6 flex flex-col gap-4 transition-all duration-200"
  style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
  onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 0 0 1px rgba(99,102,241,0.3)'"
  onmouseout="this.style.transform='none'; this.style.boxShadow='none'"
>
  <div>
    <h3 class="font-semibold text-xl" style="color: var(--color-text);">{title}</h3>
    <p class="text-sm mt-1" style="color: var(--color-muted);">{tagline}</p>
  </div>

  <ul class="space-y-1.5">
    {impact.slice(0, 2).map(item => (
      <li class="text-sm flex gap-2" style="color: color-mix(in srgb, var(--color-text) 80%, transparent);">
        <span class="mt-0.5" style="color: var(--color-accent);">✓</span>
        {item}
      </li>
    ))}
  </ul>

  <div class="flex flex-wrap gap-1.5">
    {displayTech.map(t => (
      <span
        class="text-xs px-2 py-0.5 rounded-full"
        style="background-color: var(--color-bg); color: var(--color-muted); border: 1px solid var(--color-border);"
      >
        {t}
      </span>
    ))}
    {extraCount > 0 && (
      <span
        class="text-xs px-2 py-0.5 rounded-full"
        style="background-color: var(--color-bg); color: var(--color-muted); border: 1px solid var(--color-border);"
      >
        +{extraCount}
      </span>
    )}
  </div>

  <div class="flex gap-3 mt-auto pt-2">
    <a
      href={`/projects/${project.id}`}
      class="text-sm font-medium transition-colors"
      style="color: var(--color-accent);"
    >
      View Case Study →
    </a>
    {repo && (
      <a
        href={repo}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm transition-colors"
        style="color: var(--color-muted);"
      >
        View Repo ↗
      </a>
    )}
  </div>
</article>
